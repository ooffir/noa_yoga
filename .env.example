# ─────────────────────────────────────────────────────────────────────────────
#  Noa Yogis — Environment Variables
#  Copy this file to .env and fill in the real values.
# ─────────────────────────────────────────────────────────────────────────────

# Database (Supabase) — IMPORTANT: in .env, values may be quoted; on Vercel, DO NOT wrap in quotes
DATABASE_URL="postgresql://postgres.<project>:<password>@<host>:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30"
DIRECT_URL="postgresql://postgres.<project>:<password>@<host>:5432/postgres"

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# App URL — used for Clerk redirects and server-side links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public site URL — used for payment provider return/callback URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# PayMe (https://payme.io  —  same company as paymeservice.com, just rebranded)
# Sole payment gateway. Docs: https://docs.payme.io/
PAYME_SELLER_UID=""
# Preprod (sandbox): https://preprod.payme.io/api/generate-sale
# Production:        https://ng.payme.io/api/generate-sale
PAYME_API_URL="https://preprod.payme.io/api/generate-sale"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Noa Yogis <noreply@noayogis.com>"

# Optional: Supabase Storage (for image uploads). Leave blank to use base64 fallback.
SUPABASE_SERVICE_ROLE_KEY=""

# App config
CANCELLATION_HOURS_BEFORE=6
PUNCH_CARD_CREDITS=10

# Cron auth (for /api/cron/* endpoints)
CRON_SECRET=""
